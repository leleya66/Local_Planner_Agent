# Copy this file to .env and fill in real keys before running the demo.
# Do not commit or upload the real .env file.

DASHSCOPE_API_KEY=your_dashscope_api_key_here
AMAP_API_KEY=your_amap_web_service_api_key_here

# Optional runtime settings used by the demo scripts and backend.
LOCALMATE_PORT=8041
PYTHONIOENCODING=utf-8
ENABLE_LLM_STOP_NARRATIVES=0
ENABLE_LLM_ROUTE_NARRATIVES=1

# Optional data/config overrides.
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=localmate_planning_cases
PLANNING_CASES_DIR=./planning_cases
PLACE_DATA_FILE=./all_place_mock_cleaned.xlsx
